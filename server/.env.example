# pipecat-quickstart - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
DAILY_ROOM_URL=  # Optional: leave empty to create a new room



# STT provider selection: "whisper" (local, free, no quota, default) or "cartesia" (cloud)
STT_PROVIDER=whisper

# Whisper (local STT) - used when STT_PROVIDER=whisper
WHISPER_MODEL= # Optional: defaults to "base" (good CPU speed/quality). Others: tiny, small, medium.

# Cartesia (cloud) - only needed if STT_PROVIDER=cartesia or TTS_PROVIDER=cartesia
CARTESIA_API_KEY=
CARTESIA_VOICE_ID= # Optional: only used when TTS_PROVIDER=cartesia

# TTS provider selection: "piper" (local, free, no quota, default) or "cartesia" (cloud)
TTS_PROVIDER=piper

# Piper (local TTS) - used when TTS_PROVIDER=piper
PIPER_VOICE= # Optional: defaults to "en_US-amy-medium". Other examples: en_US-ryan-high, en_GB-alba-medium
PIPER_DOWNLOAD_DIR= # Optional: where voice models are stored (defaults to ./piper_voices)


# LLM provider selection: "ollama" (local, free, default) or "deepseek" (cloud)
LLM_PROVIDER=ollama

# Ollama (local LLM) - used when LLM_PROVIDER=ollama
OLLAMA_MODEL= # Optional: defaults to "qwen2.5:1.5b" (fast). Run `ollama pull <model>` first.
OLLAMA_KEEP_ALIVE= # Optional: set on the Ollama server; "-1" keeps the model in RAM (no cold start).
OLLAMA_BASE_URL= # Optional: defaults to "http://127.0.0.1:11434/v1".
# Tip (WSL/Linux): use 127.0.0.1 not localhost — localhost may resolve to IPv6
# (::1) while Ollama listens on IPv4, causing a "Connection error".

# DeepSeek (cloud LLM) - used when LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL= # Optional: defaults to "deepseek-chat" (use "deepseek-reasoner" for deeper reasoning)

