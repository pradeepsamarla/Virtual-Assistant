# pipecat-quickstart - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
DAILY_ROOM_URL=  # Optional: leave empty to create a new room



# Cartesia (STT/TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID= # Optional: defaults to "71a7ad14-091c-4e8e-a314-022ece01c121" (British Reading Lady)

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=


# LLM provider selection: "ollama" (local, free, default) or "deepseek" (cloud)
LLM_PROVIDER=ollama

# Ollama (local LLM) - used when LLM_PROVIDER=ollama
OLLAMA_MODEL= # Optional: defaults to "qwen2.5:3b". Run `ollama pull <model>` first.
OLLAMA_BASE_URL= # Optional: defaults to "http://localhost:11434/v1"

# DeepSeek (cloud LLM) - used when LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL= # Optional: defaults to "deepseek-chat" (use "deepseek-reasoner" for deeper reasoning)

